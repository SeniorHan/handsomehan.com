---
---

<div id="search-container" class="relative">
  <button
    id="search-btn"
    class="text-text-secondary hover:text-text transition-colors text-sm flex items-center gap-1"
    aria-label="搜索"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    搜索
  </button>
</div>

<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
>
  <div class="bg-bg-card border border-border rounded-xl w-full max-w-lg mx-4 p-4 shadow-2xl">
    <div id="pagefind-search" class="[&_input]:bg-bg [&_input]:border [&_input]:border-border [&_input]:rounded-lg [&_input]:px-4 [&_input]:py-2 [&_input]:text-text [&_input]:w-full [&_input]:outline-none [&_input]:focus:border-accent [&_.pagefind-ui__result-link]:text-accent [&_.pagefind-ui__result-excerpt]:text-text-secondary [&_.pagefind-ui__result]:border-b [&_.pagefind-ui__result]:border-border [&_.pagefind-ui__result]:py-3"></div>
    <p class="text-text-secondary text-xs mt-3 text-center">按 ESC 关闭</p>
  </div>
</div>

<script is:inline>
  function initSearch() {
    var btn = document.getElementById('search-btn');
    var modal = document.getElementById('search-modal');
    var loaded = false;

    function openModal() {
      if (!modal) return;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      if (!loaded) {
        var script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = function() {
          new PagefindUI({
            element: '#pagefind-search',
            showSubResults: true,
            translations: {
              placeholder: '搜索文章...',
              zero_results: '没有找到相关文章',
            },
          });
          loaded = true;
          var input = document.querySelector('#pagefind-search input');
          if (input) input.focus();
        };
        document.head.appendChild(script);
      } else {
        var input = document.querySelector('#pagefind-search input');
        if (input) input.focus();
      }
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    if (btn) btn.addEventListener('click', openModal);
    if (modal) modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openModal();
      }
    });
  }
  initSearch();
</script>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
